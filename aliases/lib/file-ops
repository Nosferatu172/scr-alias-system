# MP4 File REPAIR.
alias repairmp4bsh='find "$(pwd)" -type f -iname "*.mp4" -exec sh -c '\'' \
  for filepath; do \
    relpath="${filepath#$(pwd)/}"; \
    outdir="repaired/$(dirname "$relpath")"; \
    mkdir -p "$outdir"; \
    outname="$(basename "$relpath")"; \
    outpath="$outdir/$outname"; \
    if [ -f "$outpath" ]; then \
      echo "Skipping $outpath (already exists)"; \
    else \
      ffmpeg -i "$filepath" -codec:v libx264 -preset fast -crf 23 "$outpath"; \
    fi; \
  done \
'\'' _ {} +'
# Convert mp4 or Mov files to mp3
vidtomp3() {
  for ext in mp4 mov; do
    for file in ./*.$ext; do
      [ -f "$file" ] || continue
      base="${file%.*}"
      output="${base}.mp3"
      if [ -f "$output" ]; then
        echo "Skipping: $output already exists."
      else
        echo "Converting: $file → $output"
        ffmpeg -i "$file" -vn -acodec libmp3lame -q:a 2 "$output"
      fi
    done
  done
}
