process_txt_loop() {
  local txt_dir="/c/Users/$WINUSERDocuments/brave"

  while true; do
    # Find the first .txt file
    txt_file=$(find "$txt_dir" -maxdepth 1 -type f -name "*.txt" | sort | head -n 1)

    # Exit if no .txt files left
    if [ -z "$txt_file" ]; then
      echo "🎉 All .txt files processed. Loop complete."
      break
    fi

    echo "🔍 Checking if download of $(basename "$txt_file") is complete..."

    # Wait for file to stop changing size (download finished)
    local size1 size2
    size1=$(stat -c%s "$txt_file")
    sleep 2
    size2=$(stat -c%s "$txt_file")

    while [ "$size1" != "$size2" ]; do
      echo "⏳ File is still downloading... waiting..."
      size1=$size2
      sleep 2
      size2=$(stat -c%s "$txt_file")
    done

    echo "✅ File ready: $(basename "$txt_file")"

    # Step 1: Set the target file (assumed to export its path somewhere `music-clm` can use)
    setxt "$txt_file"

    # Step 2: Run downloader (should read from the path set above)
    music-clm

    # Step 3: Delete the file
    dt

    echo "🌀 Finished processing: $(basename "$txt_file")"
    echo "🔁 Moving to next file if available..."
    sleep 1
  done
}
