# [section-mapper-0]
als.sections0() {
  local dir="/mnt/c/scr/aliases/lib"

  # Detect terminal width safely
  local width="${COLUMNS:-$(tput cols 2>/dev/null || echo 120)}"

  awk '
    # EXACT tag line: "# [name]"
    /^# \[[A-Za-z0-9_-]+\]$/ {
      s=$0
      sub(/^# \[/, "", s)
      sub(/\]$/, "", s)
      print s
    }
  ' "$dir"/* 2>/dev/null \
  | sort -u \
  | column -x -c "$width"
}
