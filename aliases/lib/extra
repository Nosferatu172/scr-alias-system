add-t() {
  cat << 'EOF'
WINPROFILE = ENV["WINPROFILE"]

destination_dir = "#{WINPROFILE}/Documents/tabs/"
EOF
}

searchword() {
    if [ -z "$1" ]; then
        echo "Usage: searchword <word> [directory]"
        return 1
    fi

    # Use second argument as directory, default to current folder
    local dir="${2:-.}"

    # Search for the word in all txt files, hide filenames, show line numbers
    grep -hwin "$1" "$dir"/*.txt > output.txt

    echo "Results saved to output.txt"
}

alias run_txt="for file in *.txt; do bash \"$file\"; done"
